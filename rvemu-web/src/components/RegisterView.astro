---
import Panel from "./Panel.astro";
---

<Panel title="Registers" class="register-view">
    <p><strong>Program Counter:</strong> <span id="pc-value">0x00000000</span></p>
    <table id="registers-table">
        <tbody>
            {[...Array(4)].map((_, rowIndex) => (
                <tr id={`regH${rowIndex}`} class="regH">
                    {[...Array(8)].map((_, colIndex) => {
                        const regIndex = rowIndex * 8 + colIndex;
                        return (
                            <td key={colIndex}>
                                {`x${regIndex.toString(10).padStart(2, '0')}`}
                            </td>
                        );
                    })}
                </tr>
                <tr id={`regV${rowIndex}`} class="regV">
                    {[...Array(8)].map((_, colIndex) => {
                        const regIndex = rowIndex * 8 + colIndex;
                        return (
                            <td key={colIndex} data-value={0} data-format="hex">
                                0x00000000
                            </td>
                        );
                    })}
                </tr>
            ))}
        </tbody>
    </table>
</Panel>

<style is:global>
    .register-view {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    #registers-table {
        margin-top: 1rem;
        width: 100%;
        border-collapse: collapse;
        text-align: center;
    }

    #registers-table td {
        border: 1px solid #ccc;
        padding: 0.5rem;
        font-family: monospace;
    }

    #registers-table .regH {
        background-color: #f0f0f0;
        font-weight: bold;
    }

    #registers-table .regV td:hover {
        background-color: rgb(218, 207, 255);
        cursor: pointer;
    }
</style>


<script is:inline>
    // Add a small onclick event to all register cells
    const registers_table = document.getElementById("registers-table");
    const regsV = registers_table.querySelectorAll(".regV td");

    function changeFormatMode(cell) {
        const currentFormat = cell.getAttribute("data-format");
        let newFormat;
        if (currentFormat === "hex") {
            newFormat = "dec";
        } else {
            newFormat = "hex";
        }
        cell.setAttribute("data-format", newFormat);
        // Update the cell's text based on the new format
        const value = parseInt(cell.getAttribute("data-value"), 10);
        if (newFormat === "hex") {
            cell.textContent = `0x${value.toString(16).padStart(8, '0')}`;
        } else if (newFormat === "dec") {
            cell.textContent = value.toString(10);
        } else {
            cell.textContent = "WTF?";
        }
    }

    regsV.forEach((cell) => {
        cell.addEventListener("click", () => changeFormatMode(cell));
    });
</script>