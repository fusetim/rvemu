---
import Panel from "./Panel.astro";
---

<Panel title="Logs" id="sim-logs"></Panel>

<style is:global>
    #sim-logs {
        & .panel-content {
            width: 100%;
            height: 400px;
            background-color: #f0f0f0;
            display: block;
            overflow: scroll;
            margin-top: 1rem;
            & p {
                font-size: 0.8rem;
                color: #2a2a2a;
                font-family: monospace;
            }

            &:empty {
                background-color: #ff6e6e;
            }
        }
    }
</style>
